# ---------------------------------------------------------------------------
# web-research-mcp — environment variables
# ---------------------------------------------------------------------------
# fetch_page works WITHOUT any of these variables.
# extract_data and summarize_page require Google credentials.
# ---------------------------------------------------------------------------

# Required for extract_data and summarize_page
# Your Google Cloud project ID (e.g. "my-gcp-project-123")
GOOGLE_CLOUD_PROJECT=

# Optional: override the Vertex AI region (default: us-central1)
GOOGLE_CLOUD_REGION=us-central1

# --- Credential option 1 (preferred for local dev) ---
# Path to a GCP service-account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# --- Credential option 2 (preferred for CI / remote environments) ---
# The entire service-account JSON as a single-line string.
# Useful when you cannot write files (e.g. Vercel, GitHub Actions secrets).
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
