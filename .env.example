# ==============================================================================
# web-research-mcp — environment
# ==============================================================================
# This is an MCP server (stdio transport, no HTTP). It runs locally inside
# Claude Desktop / Claude Code, so no Cloud Run / rate limit needed.

# --- Google Cloud (Vertex AI / Gemini) — required for extract_data + summarize_page ---
# The `fetch_page` tool works WITHOUT any credentials.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-key.json
